# Core settings
ENVIRONMENT=production
GUARDRAILS_ENABLED=true

# Logging
LOG_LEVEL=info

# HTTP server
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
SERVER_BASE_PATH=/api/v1
SERVER_READ_TIMEOUT=5s
# Comma-separated list, e.g. https://app.local,https://console.local
SERVER_ALLOWED_ORIGINS=
SERVER_TLS_CERTFILE=
SERVER_TLS_KEYFILE=
SERVER_ENABLE_TLS=false

# Default LLM provider
LLM_PROVIDER_NAME=default-provider
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=
LLM_REQUEST_TIMEOUT=20s
LLM_MAX_RETRIES=2
LLM_ENABLE_STREAMING=true
# Comma-separated allowlists per capability
LLM_CHAT_MODELS=
LLM_EMBED_MODELS=

# Postgres
POSTGRES_DSN=
POSTGRES_HOST=localhost
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_SSL_MODE=
POSTGRES_MAX_CONNS=20
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=
POSTGRES_MAX_CONN_IDLETIME=30s
POSTGRES_HEALTHCHECK_FREQ=30s
POSTGRES_CONNECT_TIMEOUT=10s
POSTGRES_QUERY_TIMEOUT=10s
POSTGRES_APP_NAME=

# Rate limiting
RATELIMIT_ENABLED=false
RATELIMIT_BACKEND=noop
RATELIMIT_DEFAULT_TOKENS_PER_INTERVAL=60
RATELIMIT_INTERVAL=1m
RATELIMIT_MAX_TOKENS=

# Kafka
KAFKA_BROKERS=kafka:9092

# Usage sink
USAGE_MODE=file
USAGE_FILE_PATH=logs/usage-events.log
USAGE_TOPIC=ai-proxy.usage.events

# Audit sink
AUDIT_MODE=file
AUDIT_FILE_PATH=logs/audit-events.log
AUDIT_TOPIC=ai-proxy.audit.events
