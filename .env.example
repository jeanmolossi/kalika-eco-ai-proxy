# Core settings
ENVIRONMENT=production
GUARDRAILS_ENABLED=true

# Logging
LOG_LEVEL=info

# Shared HTTP server defaults (used by local dev helpers)
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
SERVER_BASE_PATH=/api
SERVER_READ_TIMEOUT=5s
SERVER_ALLOWED_ORIGINS=
SERVER_MAX_REQUEST_BODY_BYTES=20971520
SERVER_TLS_CERTFILE=
SERVER_TLS_KEYFILE=
SERVER_ENABLE_TLS=false

# Gateway service HTTP server
GATEWAY_SERVER_HOST=0.0.0.0
GATEWAY_SERVER_PORT=8080
GATEWAY_SERVER_BASE_PATH=/api
GATEWAY_SERVER_READ_TIMEOUT=5s
GATEWAY_SERVER_ALLOWED_ORIGINS=
GATEWAY_SERVER_MAX_REQUEST_BODY_BYTES=20971520
GATEWAY_SERVER_TLS_CERTFILE=
GATEWAY_SERVER_TLS_KEYFILE=
GATEWAY_SERVER_ENABLE_TLS=false

# Tenant service HTTP server
TENANT_SERVER_HOST=0.0.0.0
TENANT_SERVER_PORT=8082
TENANT_SERVER_BASE_PATH=/api
TENANT_SERVER_READ_TIMEOUT=5s
TENANT_SERVER_ALLOWED_ORIGINS=
TENANT_SERVER_MAX_REQUEST_BODY_BYTES=20971520
TENANT_SERVER_TLS_CERTFILE=
TENANT_SERVER_TLS_KEYFILE=
TENANT_SERVER_ENABLE_TLS=false

# Guardrails service HTTP server
GUARDRAIL_SERVER_HOST=0.0.0.0
GUARDRAIL_SERVER_PORT=8083
GUARDRAIL_SERVER_BASE_PATH=/api
GUARDRAIL_SERVER_READ_TIMEOUT=5s
GUARDRAIL_SERVER_ALLOWED_ORIGINS=
GUARDRAIL_SERVER_MAX_REQUEST_BODY_BYTES=20971520
GUARDRAIL_SERVER_TLS_CERTFILE=
GUARDRAIL_SERVER_TLS_KEYFILE=
GUARDRAIL_SERVER_ENABLE_TLS=false

# Observability service HTTP server
OBSERVABILITY_SERVER_HOST=0.0.0.0
OBSERVABILITY_SERVER_PORT=8084
OBSERVABILITY_SERVER_BASE_PATH=/api
OBSERVABILITY_SERVER_READ_TIMEOUT=5s
OBSERVABILITY_SERVER_ALLOWED_ORIGINS=
OBSERVABILITY_SERVER_MAX_REQUEST_BODY_BYTES=20971520
OBSERVABILITY_SERVER_TLS_CERTFILE=
OBSERVABILITY_SERVER_TLS_KEYFILE=
OBSERVABILITY_SERVER_ENABLE_TLS=false

# Inter-service URLs
SERVICES_GATEWAY_URL=http://localhost:8080/api
SERVICES_TENANT_URL=http://localhost:8082/api
SERVICES_GUARDRAIL_URL=http://localhost:8083/api
SERVICES_OBSERVABILITY_URL=http://localhost:8084/api
SERVICES_AUTH_TOKEN=dev-shared-secret
SERVICES_REQUEST_TIMEOUT=10s
SERVICES_MAX_RETRIES=3
SERVICES_CIRCUIT_FAILURES=5
SERVICES_CIRCUIT_RESET=30s
SERVICES_CIRCUIT_INTERVAL=2m

# Default LLM provider
LLM_PROVIDER_NAME=default-provider
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=
LLM_REQUEST_TIMEOUT=20s
LLM_MAX_RETRIES=2
LLM_ENABLE_STREAMING=true
LLM_CHAT_MODELS=
LLM_EMBED_MODELS=

# Postgres shared defaults (used when module-specific values are omitted)
POSTGRES_DSN=
POSTGRES_HOST=postgres-master
POSTGRES_PORT=5432
POSTGRES_USER=ai_proxy
POSTGRES_PASSWORD=ai_proxy_password
POSTGRES_DB=ai_proxy
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_CONNS=20
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=
POSTGRES_MAX_CONN_IDLETIME=30s
POSTGRES_HEALTHCHECK_FREQ=30s
POSTGRES_CONNECT_TIMEOUT=10s
POSTGRES_QUERY_TIMEOUT=10s
POSTGRES_APP_NAME=ai-proxy-shared

# Gateway Postgres connection
GATEWAY_POSTGRES_DSN=
GATEWAY_POSTGRES_HOST=postgres-master
GATEWAY_POSTGRES_PORT=5432
GATEWAY_POSTGRES_USER=ai_proxy
GATEWAY_POSTGRES_PASSWORD=ai_proxy_password
GATEWAY_POSTGRES_DB=ai_proxy_gateway
GATEWAY_POSTGRES_SSL_MODE=disable
GATEWAY_POSTGRES_APP_NAME=gateway

# Tenant Postgres connection
TENANT_POSTGRES_DSN=
TENANT_POSTGRES_HOST=postgres-master
TENANT_POSTGRES_PORT=5432
TENANT_POSTGRES_USER=ai_proxy
TENANT_POSTGRES_PASSWORD=ai_proxy_password
TENANT_POSTGRES_DB=ai_proxy_tenant
TENANT_POSTGRES_SSL_MODE=disable
TENANT_POSTGRES_APP_NAME=tenant

# Guardrail Postgres connection
GUARDRAIL_POSTGRES_DSN=
GUARDRAIL_POSTGRES_HOST=postgres-master
GUARDRAIL_POSTGRES_PORT=5432
GUARDRAIL_POSTGRES_USER=ai_proxy
GUARDRAIL_POSTGRES_PASSWORD=ai_proxy_password
GUARDRAIL_POSTGRES_DB=ai_proxy_guardrails
GUARDRAIL_POSTGRES_SSL_MODE=disable
GUARDRAIL_POSTGRES_APP_NAME=guardrails

# Observability Postgres connection
OBSERVABILITY_POSTGRES_DSN=
OBSERVABILITY_POSTGRES_HOST=postgres-master
OBSERVABILITY_POSTGRES_PORT=5432
OBSERVABILITY_POSTGRES_USER=ai_proxy
OBSERVABILITY_POSTGRES_PASSWORD=ai_proxy_password
OBSERVABILITY_POSTGRES_DB=ai_proxy_observability
OBSERVABILITY_POSTGRES_SSL_MODE=disable
OBSERVABILITY_POSTGRES_APP_NAME=observability

# Rate limiting
RATELIMIT_ENABLED=false
RATELIMIT_BACKEND=noop
RATELIMIT_DEFAULT_TOKENS_PER_INTERVAL=60
RATELIMIT_INTERVAL=1m
RATELIMIT_MAX_TOKENS=

# Kafka
KAFKA_BROKERS=kafka:9092

# Usage sink
USAGE_MODE=file
USAGE_FILE_PATH=logs/usage-events.log
USAGE_TOPIC=ai-proxy.usage.events

# Audit sink
AUDIT_MODE=file
AUDIT_FILE_PATH=logs/audit-events.log
AUDIT_TOPIC=ai-proxy.audit.events
